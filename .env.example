# ============================================================
# The GoodLums dApp – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- OpenSea API (required for fetch-nfts.js) -------------
# Get a free key at https://docs.opensea.io/reference/api-keys
OPENSEA_API_KEY=your_opensea_api_key_here

# OpenSea collection slug (default: thegoodlums)
OPENSEA_COLLECTION_SLUG=thegoodlums

# Maximum NFTs to fetch per run (default: 200)
OPENSEA_FETCH_LIMIT=200

# ----- Local Dev Server -------------------------------------
# Port for `npm run dev` (default: 8080)
DEV_PORT=8080

# ----- OpenMythos (optional) --------------------------------
# Only required if you run `npm run openmythos:*` commands.
# OpenMythos by @kyegomez: https://github.com/kyegomez/OpenMythos
# OPENMYTHOS_API_KEY=your_openmythos_api_key_here
# OPENMYTHOS_COLLECTION_CONTEXT=thegoodlums_gang
