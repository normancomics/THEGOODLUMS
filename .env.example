# THE GOODLUMS — environment secrets example
# Copy this file to .env and fill in your values

# Your OpenSea API key (create one at https://docs.opensea.io/reference/api-overview)
OPENSEA_API_KEY=your_opensea_api_key_here

# OpenSea collection slug (do not change)
OPENSEA_COLLECTION_SLUG=thegoodlums

# Chain the main collection lives on (do not change)
OPENSEA_CHAIN=base
